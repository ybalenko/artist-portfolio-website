---
import {
  homeArtistPortrait,
  publishedHomeCarouselImages,
} from "../data/homeCarousel";
import BaseLayout from "../layouts/BaseLayout.astro";

const firstCarouselImage = publishedHomeCarouselImages[0];
const hasCarouselImages = Boolean(firstCarouselImage);
const hasMultipleCarouselImages = publishedHomeCarouselImages.length > 1;
const homeCarouselJson = JSON.stringify(publishedHomeCarouselImages);
---

<BaseLayout
  title="Yulia Balenko — Artist"
  description="The artist portfolio of Yulia Balenko."
>
  <div
    class="site-container home-content home-introduction"
    aria-labelledby="page-title"
  >
    <header class="page-intro home-page-intro">
      <p class="eyebrow">Home</p>
      <h1 id="page-title">Artist Statement</h1>
    </header>

    <div class="home-visuals">
      {
        hasCarouselImages && (
          <div class="home-carousel-shell" data-home-carousel>
            <aside class="home-carousel" aria-label="Home carousel">
              <figure class="home-carousel-figure">
                <img
                  src={firstCarouselImage.src}
                  width={firstCarouselImage.width}
                  height={firstCarouselImage.height}
                  alt={firstCarouselImage.alt}
                  fetchpriority="high"
                  data-home-carousel-image
                />
              </figure>
            </aside>

            {hasMultipleCarouselImages && (
              <p
                class="visually-hidden"
                aria-live="polite"
                data-home-carousel-status
              >
                1 / {publishedHomeCarouselImages.length}
              </p>
            )}
          </div>
        )
      }

      <aside class="home-artist-photo" aria-label="Artist portrait">
        <figure class="home-artist-photo-figure">
          <img
            src={homeArtistPortrait.src}
            width={homeArtistPortrait.width}
            height={homeArtistPortrait.height}
            alt={homeArtistPortrait.alt}
            loading="eager"
          />
        </figure>
      </aside>
    </div>

    <section class="artist-statement">
      <div class="statement-copy">
        <p>
          I paint the places, objects, and moments that make me pause. Drawn to
          subjects that evoke a sense of beauty, calm, and connection, I strive
          to capture not only what I see, but also what I feel.
        </p>
        <p>
          Many of my paintings are inspired by places I have explored while
          hiking and traveling. Others emerge from quiet, everyday moments that
          spark curiosity or leave a lasting impression. Rather than creating a
          literal representation, I seek to convey the atmosphere, light, and
          emotion that first drew me to each subject.
        </p>
        <p>
          Through my work, I hope to invite viewers to slow down, reflect, and
          discover beauty in both extraordinary landscapes and the quiet moments
          of everyday life.
        </p>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ homeCarouselJson }}>
    const homeCarouselImages = JSON.parse(homeCarouselJson);

    if (homeCarouselImages.length > 1) {
      const carousel = document.querySelector("[data-home-carousel]");
      const carouselImage = document.querySelector(
        "[data-home-carousel-image]",
      );
      const carouselStatus = document.querySelector(
        "[data-home-carousel-status]",
      );
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );

      let activeIndex = 0;
      let rotationTimer;

      const setActiveImage = (nextIndex) => {
        activeIndex =
          (nextIndex + homeCarouselImages.length) % homeCarouselImages.length;
        const image = homeCarouselImages[activeIndex];

        carouselImage.src = image.src;
        carouselImage.alt = image.alt;
        carouselImage.width = image.width;
        carouselImage.height = image.height;
        carouselStatus.textContent = `${activeIndex + 1} / ${homeCarouselImages.length}`;
      };

      const stopRotation = () => {
        window.clearInterval(rotationTimer);
      };

      const startRotation = () => {
        if (prefersReducedMotion.matches) return;

        stopRotation();
        rotationTimer = window.setInterval(() => {
          setActiveImage(activeIndex + 1);
        }, 7000);
      };

      carousel.addEventListener("mouseenter", stopRotation);
      carousel.addEventListener("mouseleave", startRotation);
      carousel.addEventListener("focusin", stopRotation);
      carousel.addEventListener("focusout", startRotation);
      prefersReducedMotion.addEventListener("change", startRotation);

      startRotation();
    }
  </script>
</BaseLayout>
