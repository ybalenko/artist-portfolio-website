---
import { portfolioSections } from "../data/portfolio";
import BaseLayout from "../layouts/BaseLayout.astro";

const firstSection = portfolioSections[0];
const firstImage = firstSection.images[0];
const portfolioJson = JSON.stringify(portfolioSections);
---

<BaseLayout
  title="Portfolio — Yulia Balenko"
  description="Selected artwork by Yulia Balenko."
>
  <div class="site-container portfolio-page" aria-labelledby="page-title">
    <header class="page-intro portfolio-intro">
      <p class="eyebrow">Portfolio</p>
      <h1 id="page-title">Selected works</h1>
    </header>

    <nav class="portfolio-section-nav" aria-label="Portfolio sections">
      {
        portfolioSections.map((section, sectionIndex) => (
          <button
            class="portfolio-section-link"
            class:list={{ active: sectionIndex === 0 }}
            type="button"
            data-section-button={section.id}
            aria-current={sectionIndex === 0 ? "true" : undefined}
          >
            {section.label}
          </button>
        ))
      }
    </nav>

    <div class="portfolio-content" data-portfolio-content>
      {
        portfolioSections.map((section, sectionIndex) => (
          <section
            class="portfolio-viewer"
            data-portfolio-section={section.id}
            aria-labelledby={`portfolio-section-${section.id}`}
            hidden={sectionIndex === 0 ? undefined : true}
          >
            <header class="portfolio-section-header">
              <h2 id={`portfolio-section-${section.id}`}>{section.label}</h2>
            </header>

            <button
              class="portfolio-feature"
              type="button"
              data-open-carousel
              data-section={section.id}
              data-index="0"
              aria-label={`Open selected ${section.label.toLowerCase()} artwork in carousel`}
            >
              <img
                data-selected-image
                src={section.images[0].src}
                width={section.images[0].width}
                height={section.images[0].height}
                alt={section.images[0].alt}
                fetchpriority={sectionIndex === 0 ? "high" : undefined}
                loading={sectionIndex === 0 ? "eager" : "lazy"}
              />
            </button>

            <div
              class="portfolio-thumbnails"
              aria-label={`${section.label} thumbnails`}
            >
              {section.images.map((image, index) => (
                <button
                  class="portfolio-thumbnail"
                  class:list={{ active: index === 0 }}
                  type="button"
                  data-thumbnail
                  data-section={section.id}
                  data-index={index}
                  aria-label={`Select ${section.label.toLowerCase()} artwork ${index + 1}`}
                  aria-current={index === 0 ? "true" : undefined}
                >
                  <img
                    src={image.src}
                    width={image.width}
                    height={image.height}
                    alt={image.alt}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </button>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    <section
      class="portfolio-carousel"
      data-carousel
      role="dialog"
      aria-modal="true"
      aria-labelledby="carousel-title"
      hidden
    >
      <h2 id="carousel-title" class="visually-hidden">Artwork carousel</h2>
      <button
        class="carousel-close"
        type="button"
        data-carousel-close
        aria-label="Close carousel"
      >
        Close
      </button>
      <button
        class="carousel-control carousel-control-previous"
        type="button"
        data-carousel-previous
        aria-label="Previous artwork"
      >
        Previous
      </button>
      <figure class="carousel-artwork">
        <img
          data-carousel-image
          src={firstImage.src}
          width={firstImage.width}
          height={firstImage.height}
          alt={firstImage.alt}
        />
      </figure>
      <button
        class="carousel-control carousel-control-next"
        type="button"
        data-carousel-next
        aria-label="Next artwork"
      >
        Next
      </button>
    </section>
  </div>

  <script is:inline define:vars={{ portfolioJson }}>
    const portfolioSections = JSON.parse(portfolioJson);
    const carousel = document.querySelector("[data-carousel]");
    const carouselImage = document.querySelector("[data-carousel-image]");
    const portfolioContent = document.querySelector("[data-portfolio-content]");
    const closeButton = document.querySelector("[data-carousel-close]");
    const previousButton = document.querySelector("[data-carousel-previous]");
    const nextButton = document.querySelector("[data-carousel-next]");
    const sectionElements = Array.from(
      document.querySelectorAll("[data-portfolio-section]"),
    );
    const sectionButtons = Array.from(
      document.querySelectorAll("[data-section-button]"),
    );
    const openButtons = Array.from(
      document.querySelectorAll("[data-open-carousel]"),
    );
    const thumbnailButtons = Array.from(
      document.querySelectorAll("[data-thumbnail]"),
    );

    let activeSectionId = portfolioSections[0].id;
    let selectedIndex = 0;
    let lastCarouselTrigger = openButtons[0];

    const getActiveSection = () =>
      portfolioSections.find((section) => section.id === activeSectionId) ??
      portfolioSections[0];

    const getActiveSectionElement = () =>
      sectionElements.find(
        (sectionElement) =>
          sectionElement.dataset.portfolioSection === activeSectionId,
      );

    const normalizeIndex = (index) => {
      const images = getActiveSection().images;
      return (index + images.length) % images.length;
    };

    const updateHash = () => {
      const image = getActiveSection().images[selectedIndex];
      if (!image) return;
      history.replaceState(null, "", `#${activeSectionId}/${image.id}`);
    };

    const setSelectedImage = (index, shouldUpdateHash = true) => {
      selectedIndex = normalizeIndex(index);
      const image = getActiveSection().images[selectedIndex];
      const activeSectionElement = getActiveSectionElement();
      const selectedImage = activeSectionElement?.querySelector(
        "[data-selected-image]",
      );
      const activeOpenButton = activeSectionElement?.querySelector(
        "[data-open-carousel]",
      );

      selectedImage.src = image.src;
      selectedImage.alt = image.alt;
      selectedImage.width = image.width;
      selectedImage.height = image.height;

      carouselImage.src = image.src;
      carouselImage.alt = image.alt;
      carouselImage.width = image.width;
      carouselImage.height = image.height;

      activeOpenButton.dataset.index = String(selectedIndex);

      thumbnailButtons.forEach((button) => {
        const isActive =
          button.dataset.section === activeSectionId &&
          Number(button.dataset.index) === selectedIndex;
        button.classList.toggle("active", isActive);
        if (isActive) {
          button.setAttribute("aria-current", "true");
        } else {
          button.removeAttribute("aria-current");
        }
      });

      if (shouldUpdateHash) {
        updateHash();
      }
    };

    const setActiveSection = (
      sectionId,
      index = 0,
      shouldUpdateHash = true,
    ) => {
      const requestedSection = portfolioSections.find(
        (section) => section.id === sectionId,
      );

      if (!requestedSection) return;

      activeSectionId = requestedSection.id;

      sectionElements.forEach((sectionElement) => {
        sectionElement.hidden =
          sectionElement.dataset.portfolioSection !== activeSectionId;
      });

      sectionButtons.forEach((button) => {
        const isActive = button.dataset.sectionButton === activeSectionId;
        button.classList.toggle("active", isActive);
        if (isActive) {
          button.setAttribute("aria-current", "true");
        } else {
          button.removeAttribute("aria-current");
        }
      });

      setSelectedImage(index, shouldUpdateHash);
    };

    const openCarousel = (trigger) => {
      lastCarouselTrigger = trigger;
      carousel.hidden = false;
      portfolioContent.setAttribute("aria-hidden", "true");
      portfolioContent.inert = true;
      closeButton.focus();
    };

    const closeCarousel = () => {
      carousel.hidden = true;
      portfolioContent.removeAttribute("aria-hidden");
      portfolioContent.inert = false;
      lastCarouselTrigger?.focus();
    };

    const showPrevious = () => setSelectedImage(selectedIndex - 1);
    const showNext = () => setSelectedImage(selectedIndex + 1);

    sectionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveSection(button.dataset.sectionButton);
      });
    });

    thumbnailButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveSection(button.dataset.section, Number(button.dataset.index));
      });

      button.addEventListener("dblclick", () => {
        setActiveSection(button.dataset.section, Number(button.dataset.index));
        openCarousel(button);
      });
    });

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveSection(button.dataset.section, Number(button.dataset.index));
        openCarousel(button);
      });
    });

    closeButton.addEventListener("click", closeCarousel);
    previousButton.addEventListener("click", showPrevious);
    nextButton.addEventListener("click", showNext);

    document.addEventListener("keydown", (event) => {
      if (carousel.hidden) return;

      if (event.key === "Escape") {
        event.preventDefault();
        closeCarousel();
      }

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        showPrevious();
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        showNext();
      }
    });

    const applyHashSelection = () => {
      const hashValue = window.location.hash.replace("#", "");
      if (!hashValue) return;

      const [sectionId, imageId] = hashValue.includes("/")
        ? hashValue.split("/")
        : ["", hashValue];
      const requestedSection = sectionId
        ? portfolioSections.find((section) => section.id === sectionId)
        : portfolioSections.find((section) =>
            section.images.some((image) => image.id === imageId),
          );

      if (!requestedSection) return;

      const imageIndex = requestedSection.images.findIndex(
        (image) => image.id === imageId,
      );

      if (imageIndex >= 0) {
        setActiveSection(requestedSection.id, imageIndex, false);
      }
    };

    window.addEventListener("hashchange", applyHashSelection);
    applyHashSelection();
  </script>
</BaseLayout>
